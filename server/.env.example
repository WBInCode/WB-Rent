# WB-Rent Server Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=3001
NODE_ENV=development

# Database (PostgreSQL) - REQUIRED
# Render: injected automatically via render.yaml (fromDatabase)
DATABASE_URL=postgresql://user:password@localhost:5432/wbrent

# CORS - comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173

# === ADMIN AUTH (REQUIRED in production - server refuses to start without them) ===
# Option A (recommended): scrypt hash of the password, format "scrypt:<saltHex>:<hashHex>"
# Generate: node -e "const c=require('crypto');const s=c.randomBytes(16);console.log('scrypt:'+s.toString('hex')+':'+c.scryptSync(process.argv[1],s,64).toString('hex'))" 'yourpassword'
# ADMIN_PASSWORD_HASH=scrypt:...:...
# Option B: plaintext password (compared timing-safe)
ADMIN_PASSWORD=change-me
# Secret used to sign admin session tokens (HMAC-SHA256). Use a long random string:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=change-me-random-64-hex

# === EMAIL ===
# Option A: Resend API (takes precedence when set)
# RESEND_API_KEY=re_...
# RESEND_FROM="WB-Rent" <noreply@wb-rent.pl>
# Option B: SMTP via Nodemailer
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-password
SMTP_FROM="WB-Rent" <noreply@wb-rent.pl>

# Admin email (where new reservation/contact notifications are sent)
ADMIN_EMAIL=admin@wb-rent.pl

# Site URL (used in email links)
SITE_URL=http://localhost:5173
# Public API base URL (used in unsubscribe links in emails)
API_URL=http://localhost:3001

# === PAYMENTS ===
# Active gateway module: payu | przelewy24 | stripe | none
PAYMENT_PROVIDER=payu

# --- PayU (base provider; values below = PUBLIC sandbox credentials from PayU docs) ---
PAYU_SANDBOX=true
PAYU_POS_ID=300746
PAYU_SECOND_KEY=b6ca15b0d1020e8094d9b5f8d163db54
PAYU_CLIENT_ID=300746
PAYU_CLIENT_SECRET=2ee86a66e5d97e3fadc400c9f19b065d

# --- Przelewy24 (fill in to switch: PAYMENT_PROVIDER=przelewy24) ---
P24_SANDBOX=true
P24_MERCHANT_ID=
P24_POS_ID=
P24_CRC=
P24_API_KEY=

# --- Stripe (fill in to switch: PAYMENT_PROVIDER=stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === ELECTRONIC RENTAL CONTRACTS ===
CONTRACTS_ENABLED=true
# Block online payment and equipment pickup until the contract is signed
CONTRACT_REQUIRED_BEFORE_PAYMENT=true
# REQUIRED in production. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONTRACT_ENCRYPTION_KEY=change-me-random-64-hex
# Private PDF storage (Docker compose mounts a persistent volume here)
CONTRACT_STORAGE_DIR=storage/contracts
CONTRACT_SIGNING_TTL_HOURS=24

# Rate limiting (global /api limiter; /admin/login has its own 10/15min)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=300
